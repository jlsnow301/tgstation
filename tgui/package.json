{
  "private": true,
  "name": "tgui-workspace",
  "version": "6.0.0",
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "tgui:analyze": "rspack --analyze",
    "tgui:bench": "rspack --env TGUI_BENCH=1 && node packages/tgui-bench/index.js",
    "tgui:build": "rspack build",
    "tgui:dev": "node --experimental-modules packages/tgui-dev-server/index.js",
    "tgui:lint": "biome ci .",
    "tgui:test": "vitest",
    "tgui:test-simple": "CI=true vitest",
    "tgui:test-ci": "CI=true vitest",
    "tgui:tsc": "tsc"
  },
  "dependencies": {
    "@rspack/cli": "^1.3.7",
    "@rspack/core": "^1.3.7",
    "css-loader": "^7.1.2",
    "jsdom": "^26.0.0",
    "sass": "^1.80.6",
    "sass-embedded": "^1.85.1",
    "sass-loader": "^16.0.3",
    "typescript": "^5.8.3",
    "url-loader": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.0",
    "@types/webpack-env": "^1.18.8",
    "@types/wicg-file-system-access": "^2023.10.6",
    "prettier": "^3.5.3",
    "vitest": "^3.1.1"
  }
}
